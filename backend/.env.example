PORT=5000
MONGODB_URI=

# Google AI Studio API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Models: if GEMINI_MODEL is set, we still try DEFAULT_CHAIN after it (2.5-lite → 2.5-flash → 2.0-flash)
# unless you set GEMINI_MODEL_FALLBACK= (empty) to lock a single model.
# GEMINI_MODEL=gemini-2.5-flash-lite
# GEMINI_MODEL_FALLBACK=gemini-2.5-flash

# 429 = Google quota/rate limit — wait, enable billing, or new API key/project.
# https://ai.google.dev/gemini-api/docs/rate-limits
